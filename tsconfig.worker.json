{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "allowImportingTsExtensions": true
  },
  "include": ["functions/**/*.ts", "src/domain/**/*.ts", "src/lib/mock-engine.ts"]
}
