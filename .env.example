# Client-side Supabase configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Set true only when running Cloudflare Pages Functions locally.
VITE_USE_LIVE_API=false
VITE_USE_DEMO_API=false
VITE_ROUTER_MODE=browser
VITE_BASE_PATH=/

# Cloudflare secrets are configured with Wrangler, not placed in this file:
# GEMINI_API_KEY
# GEMINI_MODEL=gemini-2.5-flash-lite
# RATE_LIMIT_SALT
